APP_URL=http://localhost:8000

DB_HOST=127.0.0.1
DB_NAME=the_ai_course
DB_USER=root
DB_PASS=

# 'smtp' sends real mail (main creds, fallback on failure); 'log' appends to storage/mail.log
MAIL_DRIVER=log
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME="The AI Course"

SMTP_MAIN_HOST=
SMTP_MAIN_PORT=587
SMTP_MAIN_USER=
SMTP_MAIN_PASS=
SMTP_MAIN_ENCRYPTION=tls

SMTP_FALLBACK_HOST=
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=
SMTP_FALLBACK_ENCRYPTION=tls
