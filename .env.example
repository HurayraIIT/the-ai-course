# App
APP_NAME="The AI Course"
APP_URL=http://localhost:8000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=the_ai_course
DB_USERNAME=root
DB_PASSWORD=

# Mail driver: 'smtp' sends real mail (primary, failover on failure); 'log' appends to storage/mail.log
MAIL_DRIVER=log

# SMTP — primary (default)
MAIL_PRIMARY_HOST=smtp.example.com
MAIL_PRIMARY_PORT=587
MAIL_PRIMARY_USERNAME=user@example.com
MAIL_PRIMARY_PASSWORD=secret
MAIL_PRIMARY_ENCRYPTION=tls
MAIL_PRIMARY_FROM_ADDRESS=no-reply@example.com
MAIL_PRIMARY_FROM_NAME="The AI Course"

# SMTP — failover (used when primary fails)
MAIL_FAILOVER_HOST=smtp2.example.com
MAIL_FAILOVER_PORT=587
MAIL_FAILOVER_USERNAME=user@example.com
MAIL_FAILOVER_PASSWORD=secret
MAIL_FAILOVER_ENCRYPTION=tls
MAIL_FAILOVER_FROM_ADDRESS=no-reply@example.com
MAIL_FAILOVER_FROM_NAME="The AI Course"
