---
interface Props {
  sources: string[];
  class?: string;
}
const { sources, class: className = '' } = Astro.props;

// Spans, not links: badges often sit inside an <a> row and anchors can't nest.
const META: Record<string, { label: string; classes: string }> = {
  'ai-engineer': {
    label: 'AI Engineer',
    classes: 'bg-accent-100 text-accent-800 dark:bg-accent-500/15 dark:text-accent-300',
  },
  'ai-agents': {
    label: 'AI Agents',
    classes: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-500/15 dark:text-emerald-300',
  },
  'prompt-engineering': {
    label: 'Prompt Engineering',
    classes: 'bg-amber-100 text-amber-800 dark:bg-amber-500/15 dark:text-amber-300',
  },
};
---

<span class={`inline-flex shrink-0 flex-wrap gap-1.5 ${className}`}>
  {sources.map((s) => (
    <span
      class={`rounded-full px-2 py-0.5 text-[10px] font-medium ${META[s].classes}`}
      title={`From the roadmap.sh ${META[s].label} roadmap`}
    >{META[s].label}</span>
  ))}
</span>
