<header class="site-header sticky top-0 z-40 border-b border-zinc-200 bg-white/80 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/80">
  <div class="mx-auto flex h-14 w-full max-w-5xl items-center gap-4 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid size-7 place-items-center rounded-lg bg-accent-600 text-sm font-bold text-white">AI</span>
      <span class="hidden sm:inline">The AI Course</span>
    </a>
    <nav class="flex items-center gap-4 text-sm text-zinc-600 dark:text-zinc-300">
      <a href="/course" class="hover:text-zinc-900 dark:hover:text-white">Course</a>
      <a href="/about" class="hover:text-zinc-900 dark:hover:text-white">About</a>
    </nav>
    <div class="ml-auto flex items-center gap-2">
      <button
        id="search-trigger"
        type="button"
        class="flex items-center gap-2 rounded-lg border border-zinc-200 px-2.5 py-1.5 text-sm text-zinc-500 hover:border-zinc-300 hover:text-zinc-700 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:text-zinc-200"
        aria-label="Search topics"
      >
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M17 10.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" />
        </svg>
        <span class="hidden md:inline">Search</span>
        <kbd class="hidden rounded border border-zinc-200 px-1 font-mono text-[10px] md:inline dark:border-zinc-700">⌘K</kbd>
      </button>
      <button
        id="theme-toggle"
        type="button"
        class="grid size-9 place-items-center rounded-lg border border-zinc-200 text-zinc-500 hover:border-zinc-300 hover:text-zinc-700 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:text-zinc-200"
        aria-label="Toggle dark mode"
      >
        <svg class="size-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2M5.2 5.2l1.4 1.4m10.8 10.8 1.4 1.4M3 12h2m14 0h2M5.2 18.8l1.4-1.4M17.4 6.6l1.4-1.4M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" />
        </svg>
        <svg class="hidden size-4 dark:block" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 15A9.72 9.72 0 0 1 12 21.75 9.75 9.75 0 0 1 9 2.72a.75.75 0 0 1 .94.98A8.25 8.25 0 0 0 20.3 14.06a.75.75 0 0 1 1.45.94Z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.getElementById('theme-toggle')!.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('aic:theme', dark ? 'dark' : 'light');
  });
</script>
