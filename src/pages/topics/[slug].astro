---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SourceBadges from '../../components/SourceBadges.astro';
import ResourceChecklist from '../../components/ResourceChecklist';
import { getOrderedTopics, modules } from '../../lib/course';

export async function getStaticPaths() {
  const topics = await getOrderedTopics();
  return topics.map((topic, i) => ({
    params: { slug: topic.id },
    props: {
      topic,
      prev: topics[i - 1] ? { slug: topics[i - 1].id, title: topics[i - 1].data.title } : null,
      next: topics[i + 1] ? { slug: topics[i + 1].id, title: topics[i + 1].data.title } : null,
    },
  }));
}

const { topic, prev, next } = Astro.props;
const { Content } = await render(topic);
const module = modules.find((m) => m.slug === topic.data.module)!;
const position = module.topics.indexOf(topic.id) + 1;
---

<Layout title={`${topic.data.title} — The AI Course`}>
  <article class="py-12">
    <nav class="text-sm text-zinc-500 dark:text-zinc-400" aria-label="Breadcrumb">
      <a href={`/course#${module.slug}`} class="hover:text-zinc-900 dark:hover:text-zinc-100">{module.title}</a>
      <span class="mx-2">·</span>
      <span>Topic {position} of {module.topics.length}</span>
    </nav>

    <h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl">{topic.data.title}</h1>
    <SourceBadges sources={topic.data.sources} class="mt-3" />

    <div class="prose mt-6 max-w-none">
      <Content />
    </div>

    <ResourceChecklist client:load slug={topic.id} resources={topic.data.resources} />

    <nav class="mt-12 flex gap-3 border-t border-zinc-200 pt-6 dark:border-zinc-800" aria-label="Topic navigation">
      {prev && (
        <a
          href={`/topics/${prev.slug}/`}
          class="flex min-w-0 flex-1 flex-col rounded-xl border border-zinc-200 p-4 transition-colors hover:border-accent-400 dark:border-zinc-800 dark:hover:border-accent-500"
        >
          <span class="text-xs text-zinc-500">← Previous</span>
          <span class="mt-1 truncate text-sm font-medium">{prev.title}</span>
        </a>
      )}
      {next && (
        <a
          href={`/topics/${next.slug}/`}
          class="flex min-w-0 flex-1 flex-col items-end rounded-xl border border-zinc-200 p-4 text-right transition-colors hover:border-accent-400 dark:border-zinc-800 dark:hover:border-accent-500"
        >
          <span class="text-xs text-zinc-500">Next →</span>
          <span class="mt-1 w-full truncate text-sm font-medium">{next.title}</span>
        </a>
      )}
    </nav>
  </article>
</Layout>
