---
import Layout from '../layouts/Layout.astro';
import SourceBadges from '../components/SourceBadges.astro';
import { getOrderedTopics, modules } from '../lib/course';

const topics = await getOrderedTopics();
const byModule = new Map(modules.map((m) => [m.slug, [] as typeof topics]));
for (const t of topics) byModule.get(t.data.module)!.push(t);
---

<Layout title="Curriculum — The AI Course">
  <div class="py-12">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Curriculum</h1>
    <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-400">
      All {topics.length} topics in course order. A filled dot means you marked the topic complete.
    </p>

    {modules.map((m, i) => (
      <section id={m.slug} class="mt-12 scroll-mt-20">
        <div class="flex items-baseline gap-3">
          <span class="font-mono text-lg text-zinc-400">{String(i + 1).padStart(2, '0')}</span>
          <h2 class="text-xl font-bold tracking-tight sm:text-2xl">{m.title}</h2>
        </div>
        <p class="mt-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">{m.description}</p>
        <ol class="mt-4 overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-800">
          {byModule.get(m.slug)!.map((t) => (
            <li class="border-b border-zinc-200 last:border-b-0 dark:border-zinc-800">
              <a
                href={`/topics/${t.id}/`}
                class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-zinc-50 dark:hover:bg-zinc-900"
              >
                <span
                  class="size-2.5 shrink-0 rounded-full border-2 border-zinc-300 dark:border-zinc-600"
                  data-topic-dot={t.id}
                ></span>
                <span class="grow text-sm font-medium">{t.data.title}</span>
                <SourceBadges sources={t.data.sources} class="max-sm:hidden" />
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</Layout>

<script>
  import { readProgress } from '../lib/progress';

  const progress = readProgress();
  document.querySelectorAll<HTMLElement>('[data-topic-dot]').forEach((dot) => {
    if (progress.topics[dot.dataset.topicDot!]?.done) {
      dot.classList.remove('border-2', 'border-zinc-300', 'dark:border-zinc-600');
      dot.classList.add('bg-emerald-500');
    }
  });
</script>
