---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SearchPalette from '../components/SearchPalette';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The AI Course — a free, unified curriculum covering AI engineering, AI agents, and prompt engineering.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      // Set theme before paint to avoid FOUC
      const theme = localStorage.getItem('aic:theme') ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body class="min-h-dvh bg-white font-sans text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
    <Header />
    {/* Outside <header>: its backdrop-blur creates a containing block that would trap the fixed overlay */}
    <SearchPalette client:idle />
    <main class="mx-auto w-full max-w-5xl px-4 sm:px-6">
      <slot />
    </main>
    <footer class="mx-auto mt-16 w-full max-w-5xl border-t border-zinc-200 px-4 py-8 text-sm text-zinc-500 sm:px-6 dark:border-zinc-800 dark:text-zinc-400">
      <p>
        Course structure and resource links adapted from
        <a href="https://roadmap.sh" class="underline underline-offset-2 hover:text-zinc-900 dark:hover:text-zinc-100">roadmap.sh</a>.
        Topic overviews are original. <a href="/about" class="underline underline-offset-2 hover:text-zinc-900 dark:hover:text-zinc-100">Credits &amp; data</a>.
      </p>
    </footer>
  </body>
</html>
